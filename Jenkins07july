pipeline {
    agent { label 'jenkins-Agents'}
    tools {
        jdk 'java21'
        maven 'Maven3'
   }
   stages{
        stage("cleanup the workspace"){
            steps{
              CleanWs()
                 }    
        } 

        stage("checkout from SCM"){
                steps{
                      git url: 'https://github.com/ankush2197/boxfuse-sample-java-war-hello.git',
                      branch: 'main',
                      credentialsId: 'github'
                     }
        }

        stage("Build application"){
                steps{
                    sh "mvn clean package"
                }
        }

        stage("Test application"){
                steps{
                    sh "mvn test"
                }
           } 
     }
}
